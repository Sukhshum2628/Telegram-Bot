# Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
MONGO_URI=mongodb://localhost:27017/machail-mata-bot

# Admin Configuration (Comma separated Telegram IDs)
ADMIN_IDS=123456789,987654321

# External APIs (Get a free key from openweathermap.org)
OPENWEATHER_API_KEY=your_openweathermap_api_key

# Optional
NODE_ENV=development
PORT=3000

# Google Sheets Sync (Publish to Web as CSV URLs)
SHEET_URL_HOTELS=https://docs.google.com/spreadsheets/d/e/YOUR_SHEET_ID/pub?gid=0&single=true&output=csv
SHEET_URL_VENDORS=https://docs.google.com/spreadsheets/d/e/YOUR_SHEET_ID/pub?gid=123/pub?output=csv
SHEET_URL_TAXIS=https://docs.google.com/spreadsheets/d/e/YOUR_SHEET_ID/pub?gid=456/pub?output=csv
SHEET_URL_TENTS=https://docs.google.com/spreadsheets/d/e/YOUR_SHEET_ID/pub?gid=789/pub?output=csv
SHEET_URL_EMERGENCY=https://docs.google.com/spreadsheets/d/e/YOUR_SHEET_ID/pub?gid=101112/pub?output=csv
SHEET_URL_PARKING=https://docs.google.com/spreadsheets/d/e/YOUR_SHEET_ID/pub?gid=131415/pub?output=csv
SHEET_URL_PLACES=https://docs.google.com/spreadsheets/d/e/YOUR_SHEET_ID/pub?gid=161718/pub?output=csv
