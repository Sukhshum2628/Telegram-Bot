<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">📞 Affiliate Leads Log</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a href="/admin/leads/export" class="btn btn-sm btn-outline-success">📥 Export to CSV (Proof Sheet)</a>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>User Name</th>
                        <th>User Phone</th>
                        <th>User Telegram ID</th>
                        <th>Vendor Category</th>
                        <th>Vendor Name</th>
                        <th>Vendor Contact</th>
                        <th>Clicked Timestamp</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (leads.length === 0) { %>
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">No click leads recorded yet.</td>
                        </tr>
                    <% } else { %>
                        <% leads.forEach(lead => { %>
                            <tr>
                                <td><%= lead.userName %></td>
                                <td><span class="badge bg-info text-dark font-monospace"><%= lead.userPhone %></span></td>
                                <td><code><%= lead.userId %></code></td>
                                <td>
                                    <span class="badge bg-secondary text-uppercase"><%= lead.vendorType %></span>
                                </td>
                                <td><strong><%= lead.vendorName %></strong></td>
                                <td><code><%= lead.vendorContact %></code></td>
                                <td class="text-muted"><%= new Date(lead.timestamp).toLocaleString() %></td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>
